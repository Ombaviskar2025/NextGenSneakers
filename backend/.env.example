# Server configuration
PORT=5000
NODE_ENV=development
DEBUG_SQL=false

# Database Configuration (PostgreSQL)
PGHOST=localhost
PGUSER=postgres
PGDATABASE=multivendor_db
PGPASSWORD=postgres
PGPORT=5432
# Alternatively, use a connection string:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multivendor_db

# JWT Configuration
JWT_SECRET=super_secret_access_token_key_change_me
JWT_REFRESH_SECRET=super_secret_refresh_token_key_change_me
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Google OAuth Setup
GOOGLE_CLIENT_ID=google_client_id_placeholder
GOOGLE_CLIENT_SECRET=google_client_secret_placeholder
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary Setup (Image Storage)
CLOUDINARY_CLOUD_NAME=cloudinary_cloud_name_placeholder
CLOUDINARY_API_KEY=cloudinary_api_key_placeholder
CLOUDINARY_API_SECRET=cloudinary_api_secret_placeholder

# Nodemailer Setup (Email Service)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=smtp_username_placeholder
EMAIL_PASS=smtp_password_placeholder
EMAIL_FROM=noreply@platform.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=rzp_secret_placeholder

# AI Service Configuration
GEMINI_API_KEY=gemini_api_key_placeholder
